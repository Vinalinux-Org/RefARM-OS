flowchart TD
    %% =====================================================
    %% 1. Normal task execution
    %% =====================================================
    subgraph SVC1["1. Task Execution (SVC mode)"]
        T1["Task A running
- CPU mode: SVC
- Stack: Task A stack
- PC: Task A code"]
    end

    %% =====================================================
    %% 2. Hardware interrupt entry (ARM-defined)
    %% =====================================================
    subgraph HW_IRQ["2. Interrupt Entry (Hardware)"]
        I1["Timer IRQ asserted"]
        I2["ARM exception entry:
- LR_irq ← PC + 4
- SPSR_irq ← CPSR
- CPSR.mode ← IRQ
- CPSR.I ← 1
- SP ← IRQ stack"]

        I1 --> I2
    end

    %% =====================================================
    %% 3. IRQ handling (kernel, IRQ mode)
    %% =====================================================
    subgraph IRQ_HANDLER["3. IRQ Handler (IRQ mode)"]
        H1["vector_irq / exception_entry_irq"]
        H2["irq_dispatch -> timer_isr"]
        H3["scheduler_tick (Set Flag)"]
        
        H1 --> H2 --> H3
    end

    %% =====================================================
    %% 4. Exception return (Back to Task)
    %% =====================================================
    subgraph EX_RET["4. Exception Return"]
        R1["MOVS PC, LR
(Return to interrupted Task)"]
    end
    
    H3 --> EX_RET

    %% =====================================================
    %% 5. Task Yield Decision (SVC mode)
    %% =====================================================
    subgraph YIELD["5. Task Yield Decision (SVC mode)"]
        Y1["Task Check Flag
(need_reschedule?)"]
        Y2["scheduler_yield()"]
        
        Y1 -- Yes --> Y2
        Y1 -- No  --> T1
    end
    
    EX_RET --> Y1

    %% =====================================================
    %% 6. Context Switch (SVC mode)
    %% =====================================================
    subgraph CTX["6. Context Switch (SVC mode)"]
        C1["Save Callee-Saved Registers
(r4-r11, lr)"]
        C2["Update TCB (sp)"]
        C3["Load Next Task TCB (sp)"]
        C4["Restore Callee-Saved
(r4-r11, lr)"]
        
        C1 --> C2 --> C3 --> C4
    end

    Y2 --> CTX
    CTX --> T2
    T2 -.->|"Next timer IRQ"| I1

    %% =====================================================
    %% Styling (reference-grade)
    %% =====================================================
    style SVC1 fill:#ccffcc,stroke:#333,stroke-width:3px
    style SVC2 fill:#ccffcc,stroke:#333,stroke-width:3px

    style HW_IRQ fill:#fff2cc,stroke:#333,stroke-width:3px
    style IRQ_HANDLER fill:#fff2cc,stroke:#333,stroke-width:3px

    style PREP fill:#ffcccc,stroke:#b02a37,stroke-width:3px
    style CTX fill:#ccccff,stroke:#333,stroke-width:3px
    style EX_RET fill:#e2e3e5,stroke:#333,stroke-width:3px

    style P2 fill:#ff9999,stroke:#8b0000,stroke-width:4px
