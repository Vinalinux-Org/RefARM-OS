graph TD
    subgraph PL1_Container [PL1: Privileged - Kernel Space]
        style PL1_Container fill:#fff1f0,stroke:#cf1322,stroke-width:2px
        direction LR
        SVC[<b>SVC Mode</b><br/>0x13]
        IRQ[<b>IRQ Mode</b><br/>0x12]
        ABT[<b>ABT Mode</b><br/>0x17]
        UND[<b>UND Mode</b><br/>0x1B]
        SYS[<b>SYS Mode</b><br/>0x1F]
    end

    subgraph PL0_Container [PL0: Unprivileged - User Space]
        style PL0_Container fill:#f6ffed,stroke:#389e0d,stroke-width:2px
        USR[<b>USR Mode</b><br/>0x10]
    end

    subgraph Stacks [Banked Stack Pointers]
        style Stacks fill:#f0f5ff,stroke:#1d39c4,stroke-dasharray: 5 5
        SP_svc[("SP_svc")]
        SP_irq[("SP_irq")]
        SP_abt[("SP_abt")]
        SP_und[("SP_und")]
        SP_usr[("SP_usr")]
    end

    USR -- "SVC #0 (Syscall)" --> SVC
    USR -- "Hardware IRQ" --> IRQ
    USR -- "Fault/Error" --> ABT
    USR -- "Undefined Inst" --> UND

    SVC -- "MOVS PC, LR" --> USR
    IRQ -- "LDM ... PC^" --> USR

    SVC -.-> SP_svc
    IRQ -.-> SP_irq
    ABT -.-> SP_abt
    UND -.-> SP_und
    USR -.-> SP_usr
    SYS -.-> SP_usr