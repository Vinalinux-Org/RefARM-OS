flowchart TD
    Start([Exception Occurs]) --> SaveContext[<b>Save Context</b><br/>Push Regs to Stack]
    SaveContext --> CheckMode{Source Mode?}
    
    %% Kernel Fault Path
    CheckMode -- "Privileged (SVC/SYS)" --> KernelFault[Kernel Fault]
    KernelFault --> RegDump[UART: Dump Registers / Stack Trace]
    RegDump --> Panic[PANIC: System Insecure]
    Panic --> Halt([System Halt])
    style Panic fill:#ff0000,color:#fff

    %% User Fault Path
    CheckMode -- "Unprivileged (USR)" --> UserFault[User Fault]
    UserFault --> Classify{Fault Type?}
    
    Classify -- "Data Abort" --> Log1[Log: User Data Abort]
    Classify -- "Prefetch Abort" --> Log2[Log: User Prefetch Abort]
    Classify -- "Undefined Instr" --> Log3[Log: Undefined Instruction]
    
    Log1 & Log2 & Log3 --> Containment
    
    subgraph Containment [Recovery Logic]
        MarkDead[Mark Current Task as ZOMBIE]
        PrintMsg[UART: Task Terminated]
    end
    
    Containment --> Reschedule[Scheduler: Load Next Task Context]
    Reschedule --> Resume([Exception Return: Resume System])
    
    style Resume fill:#00ff00,color:#000
    style SaveContext fill:#fff3cd,stroke:#d4a017