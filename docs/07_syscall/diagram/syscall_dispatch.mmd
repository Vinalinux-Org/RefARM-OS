flowchart TD
    Start([svc_handler]) --> GetID[Read R7: Syscall ID]
    GetID --> GetArgs[Read R0-R3: Arguments]
    GetArgs --> Dispatch{Switch R7}
    
    %% Các nhánh Syscall
    Dispatch -- 0 --> SysWrite[sys_write]
    Dispatch -- 1 --> SysExit[sys_exit]
    Dispatch -- 2 --> SysYield[sys_yield]
    Dispatch -- Other --> SysError[Error: E_INVAL]
    
    subgraph "Syscall Logic"
        SysWrite --> CheckMem{validate_ptr}
        CheckMem -- Fail --> RetPtrErr[Result: E_PTR]
        CheckMem -- OK --> DoWrite[UART/VFS Write]
        DoWrite --> RetWriteLen[Result: Written Length]
        
        SysYield --> SchedYield[scheduler_yield]
        SchedYield --> RetOK[Result: E_OK]
        
        SysExit --> LogExit[Log Status]
        LogExit --> Terminate[task_terminate]
        Terminate --> SchedNext[scheduler_dispatch_next]
        SchedNext --> NoRet((STOPS))
    end
    
    %% Gom kết quả về Register
    SysError --> SetResult
    RetPtrErr --> SetResult
    RetWriteLen --> SetResult
    RetOK --> SetResult
    
    SetResult[ctx->r0 = Result] --> Exit([Return to Assembly])

    %% Styling cho đẹp
    classDef error fill:#f96,stroke:#333,stroke-width:2px;
    classDef success fill:#9f9,stroke:#333,stroke-width:2px;
    classDef critical fill:#f66,stroke:#333,stroke-width:4px;
    
    class SysError,RetPtrErr error;
    class RetWriteLen,RetOK success;
    class NoRet critical;